generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COMMANDER
  LOGISTICS
}

enum MovementType {
  PURCHASE
  TRANSFER_IN
  TRANSFER_OUT
  ASSIGNMENT
  EXPENDED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(LOGISTICS)
  baseId    Int?
  createdAt DateTime @default(now())

  base Base? @relation(fields: [baseId], references: [id])

  logs           AuditLog[]
  assetMovements AssetMovement[]
}

model Base {
  id       Int    @id @default(autoincrement())
  name     String
  location String

  users          User[]
  inventory      Inventory[]
  assetMovements AssetMovement[]
}

model Equipment {
  id   Int    @id @default(autoincrement())
  name String
  type String

  inventory      Inventory[]
  assetMovements AssetMovement[]
}

model Inventory {
  id          Int @id @default(autoincrement())
  baseId      Int
  equipmentId Int
  quantity    Int

  base      Base      @relation(fields: [baseId], references: [id])
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([baseId, equipmentId])
}

model Purchase {
  id          Int      @id @default(autoincrement())
  baseId      Int
  equipmentId Int
  quantity    Int
  createdAt   DateTime @default(now())
}

model Transfer {
  id          Int      @id @default(autoincrement())
  fromBaseId  Int
  toBaseId    Int
  equipmentId Int
  quantity    Int
  createdAt   DateTime @default(now())
}

model Assignment {
  id          Int      @id @default(autoincrement())
  baseId      Int
  equipmentId Int
  quantity    Int
  personnel   String
  createdAt   DateTime @default(now())
}

model Expenditure {
  id          Int      @id @default(autoincrement())
  baseId      Int
  equipmentId Int
  quantity    Int
  reason      String
  createdAt   DateTime @default(now())
}

model AssetMovement {
  id          Int          @id @default(autoincrement())
  baseId      Int
  equipmentId Int
  quantity    Int
  type        MovementType
  referenceId Int?
  createdBy   Int
  createdAt   DateTime     @default(now())

  base      Base      @relation(fields: [baseId], references: [id])
  equipment Equipment @relation(fields: [equipmentId], references: [id])
  user      User      @relation(fields: [createdBy], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
